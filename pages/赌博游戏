<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>硬币投掷策略模拟器 (凯利公式游戏)</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
        }

        body {
            background-color: #f0f2f5;
            color: #333;
            padding: 20px;
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
            background: #ffffff;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.08);
            padding: 20px;
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 2px solid #edf2f7;
            padding-bottom: 15px;
            margin-bottom: 20px;
        }

        h1 {
            color: #1a365d;
            font-size: 24px;
        }

        .btn-refresh {
            background-color: #3182ce;
            color: white;
            border: none;
            padding: 10px 20px;
            font-size: 16px;
            border-radius: 6px;
            cursor: pointer;
            transition: background 0.2s;
            font-weight: bold;
        }

        .btn-refresh:hover {
            background-color: #2b6cb0;
        }

        /* 布局系统 */
        .main-layout {
            display: grid;
            grid-template-columns: 350px 1fr;
            gap: 25px;
        }

        /* 左侧硬币试验记录 */
        .left-panel {
            background: #f7fafc;
            border-radius: 8px;
            border: 1px solid #e2e8f0;
            padding: 15px;
            max-height: 850px;
            overflow-y: auto;
        }

        .panel-title {
            font-size: 16px;
            font-weight: bold;
            color: #2d3748;
            margin-bottom: 15px;
            text-align: center;
            border-bottom: 1px solid #e2e8f0;
            padding-bottom: 8px;
        }

        .coin-grid {
            display: grid;
            grid-template-columns: 60px repeat(5, 1fr);
            gap: 6px;
            align-items: center;
            font-size: 12px;
        }

        .grid-header {
            font-weight: bold;
            color: #4a5568;
            text-align: center;
            padding: 4px 0;
            background: #edf2f7;
            border-radius: 4px;
        }

        .exp-num {
            font-weight: bold;
            color: #718096;
            text-align: center;
        }

        .coin-cell {
            text-align: center;
            padding: 6px 0;
            border-radius: 4px;
            font-weight: 500;
        }

        .coin-head {
            background-color: #fed7d7;
            color: #c53030;
        }

        .coin-tail {
            background-color: #ebf8ff;
            color: #2b6cb0;
        }

        /* 右侧控制与数据大盘 */
        .right-panel {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        /* 上部参数设置与统计 */
        .top-stats-box {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .card {
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            padding: 15px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.02);
        }

        .rule-info {
            margin-top: 10px;
            font-size: 13px;
            color: #4a5568;
            line-height: 1.5;
            background: #ebf8ff;
            padding: 8px;
            border-radius: 4px;
            border-left: 4px solid #3182ce;
        }

        /* 仓位滑动条样式 */
        .slider-group {
            margin-top: 12px;
        }
        .slider-container {
            margin-bottom: 12px;
        }
        .slider-label {
            display: flex;
            justify-content: space-between;
            font-size: 14px;
            font-weight: 500;
            margin-bottom: 4px;
        }
        .custom-slider {
            width: 100%;
            height: 6px;
            border-radius: 3px;
            background: #e2e8f0;
            outline: none;
        }

        /* 中部策略对比表格 */
        .strategy-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
            font-size: 14px;
        }

        .strategy-table th, .strategy-table td {
            border: 1px solid #e2e8f0;
            padding: 10px;
            text-align: center;
        }

        .strategy-table th {
            background-color: #f7fafc;
            color: #4a5568;
            font-weight: 600;
        }

        .highlight-row {
            background-color: #f0fff4;
            font-weight: bold;
            color: #22543d;
        }
